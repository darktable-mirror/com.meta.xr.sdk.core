/*
 * RLDS (Reality Labs Design System) Light Mode Stylesheet
 * Based on RLDS Desktop design system
 */

/* ========================================
   COLOR VARIABLES (Light Mode)
   ======================================== */

:root {
    /* Surface colors */
    --rlds-surface-primary-background: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-surface-secondary-background: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-surface-tertiary-background: rgb(235, 235, 235); /* #EBEBEB */
    --rlds-surface-overlay-background: rgba(0, 0, 0, 0.32);
    --rlds-surface-unity-background: rgb(200, 200, 200); /* #C8C8C8 */

    /* Divider colors */
    --rlds-divider-primary: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-divider-secondary: rgba(39, 39, 39, 0.1); /* #2727271A */
    --rlds-border-divider: rgba(0, 0, 0, 0.2);

    /* Border colors */
    --rlds-border-focus: rgb(1, 115, 236); /* #0173EC */
    --rlds-border-card: rgba(0, 0, 0, 0.04); /* #0000000A */

    /* Navigation item colors */
    --rlds-nav-item-background-default: rgba(0, 0, 0, 0);
    --rlds-nav-item-background-hover: rgba(0, 0, 0, 0.04);
    --rlds-nav-item-background-sub-selected: rgba(0, 0, 0, 0.09);
    --rlds-nav-item-background-selected: rgba(0, 0, 0, 0.17);

    /* Button backgrounds */
    --rlds-button-primary-background-default: rgb(39, 39, 39); /* #272727 */
    --rlds-button-primary-background-hover: rgb(90, 90, 90); /* #5A5A5A */
    --rlds-button-primary-background-pressed: rgb(116, 116, 116); /* #747474 */
    --rlds-button-secondary-background-default: rgba(0, 0, 0, 0.04); /* #0000000A */
    --rlds-button-secondary-background-hover: rgba(0, 0, 0, 0.09); /* #00000017 */
    --rlds-button-secondary-background-pressed: rgba(0, 0, 0, 0.17); /* #0000002B */
    --rlds-button-tertiary-background-default: rgba(0, 0, 0, 0); /* #00000000 */
    --rlds-button-tertiary-background-hover: rgba(0, 0, 0, 0.09); /* #00000017 */
    --rlds-button-tertiary-background-pressed: rgba(0, 0, 0, 0.17); /* #0000002B */
    --rlds-button-onmedia-background-default: rgba(255, 255, 255, 0); /* #FFFFFF00 */
    --rlds-button-onmedia-background-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-button-onmedia-background-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-button-deselected-background-default: rgba(0, 0, 0, 0.04); /* #0000000A */
    --rlds-button-deselected-background-hover: rgba(0, 0, 0, 0.09); /* #00000017 */
    --rlds-button-deselected-background-pressed: rgba(0, 0, 0, 0.17); /* #0000002B */
    --rlds-button-selected-background-default: rgb(39, 39, 39); /* #272727 */
    --rlds-button-selected-background-hover: rgba(0, 0, 0, 0.89); /* #000000E3 */
    --rlds-button-selected-background-pressed: rgba(0, 0, 0, 0.94); /* #000000F0 */
    --rlds-button-disable-background: rgb(192, 192, 192); /* #C0C0C0 */
    --rlds-button-special-background-stop-1: rgb(137, 235, 106); /* #89EB6A */
    --rlds-button-special-background-stop-2: rgb(0, 120, 125); /* #00787D */
    --rlds-button-special-background-stop-3: rgb(0, 120, 125); /* #00787D */
    --rlds-button-special-background-stop-4: rgb(4, 161, 161); /* #04A1A1 */

    /* Border colors */
    --rlds-border-color: rgb(39, 39, 39); /* #272727 */
    --rlds-border-color-dark: rgb(48, 48, 48); /* #303030 */

    /* Icon UI colors */
    --rlds-icon-ui-primary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-ui-secondary: rgb(39, 39, 39); /* #272727 */
    --rlds-icon-ui-tertiary: rgb(39, 39, 39); /* #272727 */
    --rlds-icon-ui-disabled: rgba(0, 0, 0, 0.32); /* #00000052 */
    --rlds-icon-ui-onmedia: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-icon-ui-selected: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-icon-ui-deselected: rgb(39, 39, 39); /* #272727 */

    /* Icon semantic colors */
    --rlds-icon-positive: rgb(11, 138, 27); /* #0B8A1B */
    --rlds-icon-negative: rgb(221, 21, 53); /* #DD1535 */
    --rlds-icon-warning: rgb(169, 67, 2); /* #A94302 */
    --rlds-icon-notification: rgb(1, 115, 236); /* #0173EC */
    --rlds-icon-privacy: rgb(117, 91, 228); /* #755BE4 */

    /* Icon general colors */
    --rlds-icon-primary: rgb(39, 39, 39); /* #272727 */
    --rlds-icon-secondary: rgba(0, 0, 0, 0.6); /* #00000099 */
    --rlds-icon-onmedia: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-secondary-onmedia: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */
    --rlds-icon-disabled: rgba(0, 0, 0, 0.26); /* #00000042 */
    --rlds-icon-placeholder: rgba(0, 0, 0, 0.32); /* #00000052 */
    --rlds-icon-object-instance: rgb(1, 78, 208); /* #014ED0 */

    /* Text UI colors */
    --rlds-text-ui-primary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-ui-secondary: rgb(39, 39, 39); /* #272727 */
    --rlds-text-ui-tertiary: rgb(39, 39, 39); /* #272727 */
    --rlds-text-ui-onmedia: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-text-ui-disabled: rgba(0, 0, 0, 0.32); /* #00000052 */
    --rlds-text-ui-deselected: rgb(39, 39, 39); /* #272727 */
    --rlds-text-ui-selected: rgb(242, 242, 242); /* #F2F2F2 */

    /* Text general colors */
    --rlds-text-primary: rgb(39, 39, 39); /* #272727 */
    --rlds-text-secondary: rgba(0, 0, 0, 0.6); /* #00000099 */
    --rlds-text-placeholder: rgba(0, 0, 0, 0.32); /* #00000052 */
    --rlds-text-disabled: rgba(0, 0, 0, 0.26); /* #00000042 */
    --rlds-text-primary-onmedia: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-secondary-onmedia: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */

    /* Text semantic colors */
    --rlds-text-warning: rgb(169, 67, 2); /* #A94302 */
    --rlds-text-link: rgb(1, 115, 236); /* #0173EC */
    --rlds-text-positive: rgb(11, 138, 27); /* #0B8A1B */
    --rlds-text-negative: rgb(221, 21, 53); /* #DD1535 */
    --rlds-text-object-instance: rgb(1, 78, 208); /* #014ED0 */
    --rlds-text-online: rgb(11, 135, 79); /* #0B874F */
    --rlds-text-screenshare: rgb(0, 120, 125); /* #00787D */

    /* Icon screenshare */
    --rlds-icon-screenshare: rgb(4, 161, 161); /* #04A1A1 */

    /* State overlay colors */
    --rlds-state-overlay-hover: rgba(0, 0, 0, 0.1);
    --rlds-state-overlay-pressed: rgba(0, 0, 0, 0.2);
    --rlds-state-overlay-selected: rgb(39, 39, 39); /* #272727 */
    --rlds-state-overlay-primary-button-hover: rgba(255, 255, 255, 0.2);
    --rlds-state-overlay-primary-button-pressed: rgba(255, 255, 255, 0.3);
    --rlds-state-overlay-auxiliary-hover: rgba(0, 0, 0, 0.2);
    --rlds-state-overlay-auxiliary-pressed: rgba(0, 0, 0, 0.3);
    --rlds-state-overlay-on-media-hover: rgba(255, 255, 255, 0.1);
    --rlds-state-overlay-on-media-pressed: rgba(255, 255, 255, 0.2);

    /* Viewport colors */
    --rlds-viewport-canvas: rgb(221, 221, 221); /* #DDDDDD */

    /* Badge colors */
    --rlds-badge-positive: rgb(11, 138, 27); /* #0B8A1B */
    --rlds-badge-negative: rgb(221, 21, 53); /* #DD1535 */
    --rlds-badge-warning: rgb(169, 67, 2); /* #A94302 */
    --rlds-badge-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-badge-default: rgb(39, 39, 39); /* #272727 */
    --rlds-badge-privacy: rgb(117, 91, 228); /* #755BE4 */
    --rlds-badge-default-light-background: rgba(0, 0, 0, 0.04);
    --rlds-badge-positive-light-background: rgba(11, 138, 27, 0.05);
    --rlds-badge-warning-light-background: rgba(169, 67, 2, 0.05);
    --rlds-badge-negative-light-background: rgba(221, 21, 53, 0.05);
    --rlds-badge-notification-light-background: rgba(1, 115, 236, 0.05);
    --rlds-badge-privacy-light-background: rgba(117, 91, 228, 0.05);

    /* Badge Pill border colors (50% opacity of base, except Neutral at 40%) */
    --rlds-badge-pill-positive-border: rgba(11, 138, 27, 0.5);
    --rlds-badge-pill-notification-border: rgba(1, 115, 236, 0.5);
    --rlds-badge-pill-warning-border: rgba(169, 67, 2, 0.5);
    --rlds-badge-pill-negative-border: rgba(221, 21, 53, 0.5);
    --rlds-badge-pill-neutral-border: rgba(0, 0, 0, 0.4);

    /* Chip colors */
    --rlds-chip-background-default: rgba(0, 0, 0, 0);
    --rlds-chip-background-hover: rgba(0, 0, 0, 0.09);
    --rlds-chip-background-pressed: rgba(0, 0, 0, 0.21);
    --rlds-chip-background-selected: rgb(39, 39, 39); /* #272727 */

    /* Graph series colors */
    --rlds-graph-series-1: rgb(1, 115, 236); /* #0173EC */
    --rlds-graph-series-2: rgb(22, 156, 96); /* #169C60 */
    --rlds-graph-series-3: rgb(139, 83, 1); /* #8B5301 */
    --rlds-graph-series-4: rgb(169, 67, 2); /* #A94302 */
    --rlds-graph-series-5: rgb(221, 21, 53); /* #DD1535 */
    --rlds-graph-series-6: rgb(167, 42, 130); /* #A72A82 */
    --rlds-graph-series-7: rgb(100, 65, 210); /* #6441D2 */
    --rlds-graph-series-8: rgb(0, 117, 169); /* #0075A9 */
    --rlds-graph-series-9: rgb(90, 90, 90); /* #5A5A5A */
    --rlds-graph-series-10: rgb(13, 13, 13); /* #0D0D0D */

    /* Input colors */
    --rlds-input-default: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-input-disabled: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-input-hover: rgba(0, 0, 0, 0.32); /* #00000052 */
    --rlds-input-pressed: rgba(0, 0, 0, 0.21); /* #00000036 */
    --rlds-input-selected: rgb(39, 39, 39); /* #272727 */

    /* Toggle colors */
    --rlds-toggle-thumb-default: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-toggle-thumb-hover: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-toggle-thumb-pressed: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-toggle-thumb-disabled: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-toggle-thumb-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Slider colors */
    --rlds-slider-track-default: rgba(0, 0, 0, 0.04); /* #0000000A */
    --rlds-slider-track-hover: rgba(0, 0, 0, 0.38); /* #00000061 */
    --rlds-slider-track-disabled: rgb(192, 192, 192); /* #C0C0C0 */
    --rlds-slider-track-selected: rgba(0, 0, 0, 0.77); /* #000000C4 */

    /* Radio button icon colors */
    --rlds-radio-button-icon-default: rgba(255, 255, 255, 0);
    --rlds-radio-button-icon-hover: rgba(255, 255, 255, 0);
    --rlds-radio-button-icon-pressed: rgba(255, 255, 255, 0);
    --rlds-radio-button-icon-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Checkbox icon colors */
    --rlds-checkbox-icon-default: rgba(255, 255, 255, 0);
    --rlds-checkbox-icon-hover: rgba(255, 255, 255, 0);
    --rlds-checkbox-icon-pressed: rgba(255, 255, 255, 0);
    --rlds-checkbox-icon-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Progress bar colors */
    --rlds-progress-bar-empty: rgba(0, 0, 0, 0.06); /* #0000000F */
    --rlds-progress-bar-error: rgb(221, 21, 53); /* #DD1535 */
    --rlds-progress-bar-filled: rgb(11, 138, 27); /* #0B8A1B */
    --rlds-progress-bar-indeterminate: rgb(20, 139, 253); /* #148BFD */
    --rlds-progress-bar-determinate-fill: rgb(39, 39, 39); /* #272727 */
    --rlds-progress-bar-determinate-background: rgba(0, 0, 0, 0.06); /* #0000000F */

    /* Progress ring colors */
    --rlds-progress-ring-foreground-default: rgb(1, 115, 236); /* #0173EC */
    --rlds-progress-ring-foreground-accent: rgb(11, 138, 27); /* #0B8A1B */
    --rlds-progress-ring-foreground-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-progress-ring-foreground-dark: rgb(39, 39, 39); /* #272727 */
    --rlds-progress-ring-foreground-light: rgb(255, 255, 255); /* #FFFFFF */

    /* Font sizes */
    --rlds-font-size-4xl: 56px;
    --rlds-font-size-3xl: 32px;
    --rlds-font-size-2xl: 24px;
    --rlds-font-size-xl: 20px;
    --rlds-font-size-lg: 16px;
    --rlds-font-size-md: 14px;
    --rlds-font-size-sm: 12px;
    --rlds-font-size-xs: 11px;
    --rlds-font-size-2xs: 10px;

    /* Font weights */
    --rlds-font-weight-bold: bold;
    --rlds-font-weight-semibold: 600;
    --rlds-font-weight-medium: 500;
    --rlds-font-weight-regular: normal;

    /* Line heights */
    --rlds-line-height-8xl: 60px;
    --rlds-line-height-7xl: 52px;
    --rlds-line-height-6xl: 44px;
    --rlds-line-height-5xl: 40px;
    --rlds-line-height-4xl: 36px;
    --rlds-line-height-3xl: 28px;
    --rlds-line-height-2xl: 26px;
    --rlds-line-height-xl: 24px;
    --rlds-line-height-lg: 20px;
    --rlds-line-height-md: 18px;
    --rlds-line-height-sm: 16px;
    --rlds-line-height-xs: 13px;

    /* Letter spacing */
    --rlds-letter-spacing-title: -1px;
    --rlds-letter-spacing-heading: -0.5px;
    --rlds-letter-spacing-eyebrow: 0.3px;
    --rlds-letter-spacing-normal: 0px;

    /* Spacing */
    --rlds-spacing-none: 0px;
    --rlds-spacing-4xs: 2px;
    --rlds-spacing-3xs: 4px;
    --rlds-spacing-2xs: 6px;
    --rlds-spacing-xs: 8px;
    --rlds-spacing-sm: 12px;
    --rlds-spacing-md: 16px;
    --rlds-spacing-2x-md: 32px;
    --rlds-spacing-lg: 20px;
    --rlds-spacing-xl: 24px;
    --rlds-spacing-2xl: 32px;
    --rlds-spacing-3xl: 40px;
    --rlds-spacing-4xl: 48px;
    --rlds-spacing-5xl: 64px;

    /* Border radius */
    --rlds-radius-none: 0px;
    --rlds-radius-xs: 4px;
    --rlds-radius-sm: 8px;
    --rlds-radius-md: 14px;
    --rlds-radius-lg: 20px;
    --rlds-radius-xl: 32px;
    --rlds-radius-full: 1000px;

    /* Icon sizes */
    --rlds-icon-size-2xs: 8px;
    --rlds-icon-size-xs: 12px;
    --rlds-icon-size-sm: 16px;
    --rlds-icon-size-md: 18px;
    --rlds-icon-size-lg: 24px;
    --rlds-icon-size-xl: 32px;
    --rlds-icon-size-2xl: 48px;
    --rlds-icon-size-3xl: 72px;

    /* Thumbnail sizes */
    --rlds-thumbnail-xs: 24px;
    --rlds-thumbnail-sm: 32px;
    --rlds-thumbnail-md: 40px;
    --rlds-thumbnail-lg: 48px;
    --rlds-thumbnail-xl: 56px;
    --rlds-thumbnail-2xl: 64px;
    --rlds-thumbnail-3xl: 72px;
    --rlds-thumbnail-4xl: 96px;
    --rlds-thumbnail-5xl: 120px;

    /* Border width */
    --rlds-border-width: 1px;
    --rlds-border-width-none: 0px;
    --rlds-border-width-sm: 1px;
    --rlds-border-width-md: 2px;
    --rlds-border-width-lg: 4px;

    /* Button sizes - Large */
    --rlds-button-large-height: 44px;
    --rlds-button-large-min-width: 120px;
    --rlds-button-large-padding-horizontal: 24px;
    --rlds-button-large-padding-vertical: 12px;

    /* Button sizes - Small */
    --rlds-button-small-height: 32px;
    --rlds-button-small-min-width: 80px;
    --rlds-button-small-padding-horizontal: 12px;
    --rlds-button-small-padding-vertical: 6px;

    /* Button sizes - XSmall */
    --rlds-button-xsmall-height: 24px;
    --rlds-button-xsmall-min-width: 60px;
    --rlds-button-xsmall-padding-horizontal: 8px;
    --rlds-button-xsmall-padding-vertical: 4px;

    /* Shadow colors - Light mode (Unity USS does not support box-shadow; use these as reference colors) */
    --rlds-shadow-punched-in-drop-shadow: rgb(255, 255, 255);
    --rlds-shadow-punched-in-inner-shadow: rgba(0, 0, 0, 0.04);
    --rlds-shadow-beveled-left: rgb(255, 255, 255);
    --rlds-shadow-beveled-right: rgba(0, 0, 0, 0.04);
    --rlds-shadow-drop-shadow-toggle: rgba(0, 0, 0, 0.09);
    --rlds-shadow-drop-shadow-inner-shadow-left: rgb(255, 255, 255);
    --rlds-shadow-drop-shadow-inner-shadow-right: rgba(0, 0, 0, 0.04);
    --rlds-shadow-drop-shadow-drop-shadow-top: rgba(0, 0, 0, 0.04);
    --rlds-shadow-drop-shadow-drop-shadow-bottom: rgba(0, 0, 0, 0.04);
    --rlds-shadow-elevation-0-drop-shadow-1: rgba(0, 0, 0, 0.09);
    --rlds-shadow-elevation-0-drop-shadow-2: rgba(0, 0, 0, 0.17);
    --rlds-shadow-elevation-1-drop-shadow-1: rgba(0, 0, 0, 0.04);
    --rlds-shadow-elevation-1-drop-shadow-2: rgba(0, 0, 0, 0.04);
    --rlds-shadow-elevation-2-drop-shadow-1: rgba(0, 0, 0, 0.09);
    --rlds-shadow-elevation-2-drop-shadow-2: rgba(0, 0, 0, 0.04);

    /* Spinner colors */
    --rlds-spinner-fill-background: rgb(39, 39, 39); /* #272727 */
    --rlds-spinner-track-background: rgba(0, 0, 0, 0.09); /* #00000017 */
}

/* ========================================
   TYPOGRAPHY STYLES
   ======================================== */

.rlds-title {
    font-size: var(--rlds-font-size-4xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-title-italic {
    font-size: var(--rlds-font-size-4xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading1 {
    font-size: var(--rlds-font-size-3xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading1-italic {
    font-size: var(--rlds-font-size-3xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading2 {
    font-size: var(--rlds-font-size-xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading2-italic {
    font-size: var(--rlds-font-size-xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading3 {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading3-italic {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading4 {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading4-italic {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-body1-label {
    font-size: var(--rlds-font-size-md);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

