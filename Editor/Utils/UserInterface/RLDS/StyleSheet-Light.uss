    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - SMALL SECONDARY
   ======================================== */

.rlds-button-secondary-small {
    height: var(--rlds-button-small-height);
    min-width: var(--rlds-button-small-min-width);
    padding: var(--rlds-button-small-padding-vertical) var(--rlds-button-small-padding-horizontal);
    background-color: var(--rlds-button-secondary-background-default);
    color: var(--rlds-text-ui-secondary);
    border-radius: var(--rlds-radius-xs);
    font-size: 12px;
