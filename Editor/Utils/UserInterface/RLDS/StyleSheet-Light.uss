}

.rlds-button-secondary-small:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* Danger modifier — apply alongside .rlds-button-secondary-small for a destructive
   action (e.g. Deactivate). Overrides background/text only; size, padding, radius,
   and typography are inherited from the base class. */
.rlds-button-secondary-small--danger {
    background-color: rgb(140, 38, 38); /* #8C2626 */
    color: rgb(255, 255, 255);
}

.rlds-button-secondary-small--danger:hover {
    background-color: rgb(165, 50, 50); /* #A53232 */
}

.rlds-button-secondary-small--danger:active {
    background-color: rgb(115, 30, 30); /* #731E1E */
}

.rlds-button-secondary-small--danger:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

